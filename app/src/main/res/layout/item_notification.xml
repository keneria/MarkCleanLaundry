<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp">

        <!-- Icon -->
        <ImageView
            android:id="@+id/ivNotifIcon"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_centerVertical="true"
            android:layout_marginEnd="12dp"
            android:scaleType="fitCenter"
            android:src="@drawable/order_confirmed" />

        <!-- Unread dot -->
        <TextView
            android:id="@+id/tvUnreadDot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_alignTop="@id/ivNotifIcon"
            android:layout_alignEnd="@id/ivNotifIcon"
            android:background="@drawable/dot_blue"
            android:visibility="gone" />

        <!-- Time (top right) -->
        <TextView
            android:id="@+id/tvNotifTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_alignParentTop="true"
            android:fontFamily="@font/lexend_medium"
            android:text="—"
            android:textColor="#AAAAAA"
            android:textSize="10sp" />

        <!-- Title + Message -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_toEndOf="@id/ivNotifIcon"
            android:layout_toStartOf="@id/tvNotifTime"
            android:orientation="vertical"
            android:paddingEnd="8dp">

            <TextView
                android:id="@+id/tvNotifTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/lexend_bold"
                android:text="Title"
                android:textColor="#1B3A5C"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvNotifMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:fontFamily="@font/lexend_medium"
                android:text="Message"
                android:textColor="#888888"
                android:textSize="11sp"
                android:maxLines="2"
                android:ellipsize="end" />

        </LinearLayout>

    </RelativeLayout>

</androidx.cardview.widget.CardView>