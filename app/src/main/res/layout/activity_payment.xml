<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#F5F5F5"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#F5F5F5"
            app:contentInsetStart="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="4dp"
                android:paddingEnd="16dp">

                <ImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/back"
                    android:scaleType="fitCenter"
                    android:padding="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:tint="#1B3A5C"
                    android:contentDescription="Back" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Confirm Booking"
                    android:textColor="#1B3A5C"
                    android:textSize="20sp"
                    android:fontFamily="@font/lexend_bold" />

            </LinearLayout>
        </androidx.appcompat.widget.Toolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="100dp"
        android:clipToPadding="false"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="20dp">

            <!-- ===== ORDER SUMMARY ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Order Summary"
                android:textColor="#1B3A5C"
                android:textSize="16sp"
                android:fontFamily="@font/lexend_bold"
                android:layout_marginBottom="10dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Service"
                            android:textColor="#888888"
                            android:textSize="13sp"
                            android:fontFamily="@font/lexend_medium" />

                        <TextView
                            android:id="@+id/tvPaymentServiceName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="#1B3A5C"
                            android:textSize="13sp"
                            android:fontFamily="@font/lexend_bold"
                            android:layout_alignParentEnd="true" />

                    </RelativeLayout>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Method"
                            android:textColor="#888888"
                            android:textSize="13sp"
                            android:fontFamily="@font/lexend_medium" />

                        <TextView
                            android:id="@+id/tvPaymentMethod"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="#1B3A5C"
                            android:textSize="13sp"
                            android:fontFamily="@font/lexend_bold"
                            android:layout_alignParentEnd="true" />

                    </RelativeLayout>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Service Type"
                            android:textColor="#888888"
                            android:textSize="13sp"
                            android:fontFamily="@font/lexend_medium" />

                        <TextView
                            android:id="@+id/tvPaymentServiceType"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="#1B3A5C"
                            android:textSize="13sp"
                            android:fontFamily="@font/lexend_bold"
                            android:layout_alignParentEnd="true" />

                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#EEEEEE"
                        android:layout_marginTop="4dp" />

                    <!-- Rate notice — hidden in claiming mode -->
                    <LinearLayout
                        android:id="@+id/layoutRateNotice"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rate: ₱120.00/kg — Total will be calculated after the store weighs your laundry."
                            android:textColor="#AAAAAA"
                            android:textSize="11sp"
                            android:fontFamily="@font/lexend_medium"
                            android:layout_marginTop="12dp" />

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ===== ADDRESS ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Address"
                android:textColor="#1B3A5C"
                android:textSize="16sp"
                android:fontFamily="@font/lexend_bold"
                android:layout_marginBottom="10dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Store address (Drop-off only) -->
                    <LinearLayout
                        android:id="@+id/tvStoreAddress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:visibility="gone">

                        <View
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:layout_marginEnd="12dp"
                            android:layout_marginTop="4dp"
                            android:background="@drawable/dot_dark" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Store Address"
                                android:textColor="#1B3A5C"
                                android:textSize="13sp"
                                android:fontFamily="@font/lexend_bold"
                                android:layout_marginBottom="4dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Ground floor MIM Bldg., 2993 Kakarong St. Brgy. Sta Cruz, Makati City"
                                android:textColor="#444444"
                                android:textSize="12sp"
                                android:fontFamily="@font/lexend_medium"
                                android:layout_marginBottom="6dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Please show your order receipt at the counter when dropping off your laundry."
                                android:textColor="#888888"
                                android:textSize="11sp"
                                android:fontFamily="@font/lexend_medium" />

                        </LinearLayout>
                    </LinearLayout>

                    <!-- Pickup address (Home Pickup booking) -->
                    <LinearLayout
                        android:id="@+id/layoutPickupAddress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:visibility="gone">

                        <View
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:layout_marginEnd="12dp"
                            android:layout_marginTop="4dp"
                            android:background="@drawable/dot_blue" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Pickup Address"
                                android:textColor="#1B3A5C"
                                android:textSize="13sp"
                                android:fontFamily="@font/lexend_bold"
                                android:layout_marginBottom="8dp" />

                            <EditText
                                android:id="@+id/etPickupAddress"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="e.g. Unit 4B, Rizal Bldg., España St., Sampaloc, Manila"
                                android:textColor="#444444"
                                android:textColorHint="#CCCCCC"
                                android:textSize="12sp"
                                android:fontFamily="@font/lexend_medium"
                                android:background="@drawable/date_selector_bg"
                                android:padding="12dp"
                                android:inputType="textPostalAddress|textCapSentences"
                                android:minLines="2"
                                android:maxLines="4"
                                android:gravity="top" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Format: Unit/House No., Building, Street, Barangay, City"
                                android:textColor="#AAAAAA"
                                android:textSize="10sp"
                                android:fontFamily="@font/lexend_medium"
                                android:layout_marginTop="6dp" />

                        </LinearLayout>
                    </LinearLayout>

                    <!-- Claiming: Home Delivery address input -->
                    <LinearLayout
                        android:id="@+id/layoutClaimingDeliveryAddress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:visibility="gone">

                        <View
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:layout_marginEnd="12dp"
                            android:layout_marginTop="4dp"
                            android:background="@drawable/dot_blue" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Delivery Address"
                                android:textColor="#1B3A5C"
                                android:textSize="13sp"
                                android:fontFamily="@font/lexend_bold"
                                android:layout_marginBottom="8dp" />

                            <EditText
                                android:id="@+id/etClaimingDeliveryAddress"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="e.g. Unit 4B, Rizal Bldg., España St., Sampaloc, Manila"
                                android:textColor="#444444"
                                android:textColorHint="#CCCCCC"
                                android:textSize="12sp"
                                android:fontFamily="@font/lexend_medium"
                                android:background="@drawable/date_selector_bg"
                                android:padding="12dp"
                                android:inputType="textPostalAddress|textCapSentences"
                                android:minLines="2"
                                android:maxLines="4"
                                android:gravity="top" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Format: Unit/House No., Building, Street, Barangay, City"
                                android:textColor="#AAAAAA"
                                android:textSize="10sp"
                                android:fontFamily="@font/lexend_medium"
                                android:layout_marginTop="6dp" />

                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ===== PAYMENT METHOD ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Payment Method"
                android:textColor="#1B3A5C"
                android:textSize="16sp"
                android:fontFamily="@font/lexend_bold"
                android:layout_marginBottom="10dp" />

            <!-- HOME PICK-UP payment options (GCash + COD) -->
            <LinearLayout
                android:id="@+id/layoutPaymentPickup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- GCash (Pick-up) -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardGcash"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="16dp">

                            <RadioButton
                                android:id="@+id/rbGcash"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_centerVertical="true"
                                android:buttonTint="#2C8FBD" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:layout_toEndOf="@id/rbGcash"
                                android:layout_marginStart="8dp"
                                android:layout_centerVertical="true">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="GCash"
                                    android:textColor="#1B3A5C"
                                    android:textSize="14sp"
                                    android:fontFamily="@font/lexend_bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Pay via GCash after store weighs your laundry"
                                    android:textColor="#AAAAAA"
                                    android:textSize="11sp"
                                    android:fontFamily="@font/lexend_medium" />

                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="G"
                                android:textColor="#FFFFFF"
                                android:textSize="18sp"
                                android:fontFamily="@font/lexend_bold"
                                android:background="#007DFF"
                                android:paddingStart="10dp"
                                android:paddingEnd="10dp"
                                android:paddingTop="4dp"
                                android:paddingBottom="4dp"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true" />

                        </RelativeLayout>

                        <LinearLayout
                            android:id="@+id/layoutGcashFields"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:visibility="gone"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:paddingBottom="16dp">

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:background="#EEEEEE"
                                android:layout_marginBottom="12dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="GCash Number"
                                android:textColor="#AAAAAA"
                                android:textSize="11sp"
                                android:fontFamily="@font/lexend_medium"
                                android:layout_marginBottom="6dp" />

                            <EditText
                                android:id="@+id/etGcashNumber"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="09XX XXX XXXX"
                                android:textColor="#444444"
                                android:textColorHint="#CCCCCC"
                                android:textSize="13sp"
                                android:fontFamily="@font/lexend_medium"
                                android:background="@drawable/date_selector_bg"
                                android:padding="12dp"
                                android:inputType="phone"
                                android:maxLines="1"
                                android:layout_marginBottom="12dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Account Name"
                                android:textColor="#AAAAAA"
                                android:textSize="11sp"
                                android:fontFamily="@font/lexend_medium"
                                android:layout_marginBottom="6dp" />

                            <EditText
                                android:id="@+id/etGcashName"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Full name on GCash account"
                                android:textColor="#444444"
                                android:textColorHint="#CCCCCC"
                                android:textSize="13sp"
                                android:fontFamily="@font/lexend_medium"
                                android:background="@drawable/date_selector_bg"
                                android:padding="12dp"
                                android:inputType="textCapWords"
                                android:maxLines="1" />

                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- COD (Pick-up) -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardCod"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="24dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">

                        <RadioButton
                            android:id="@+id/rbCod"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:buttonTint="#2C8FBD" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_toEndOf="@id/rbCod"
                            android:layout_marginStart="8dp"
                            android:layout_centerVertical="true">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Cash on Delivery"
                                android:textColor="#1B3A5C"
                                android:textSize="14sp"
                                android:fontFamily="@font/lexend_bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Pay cash when you receive your laundry"
                                android:textColor="#AAAAAA"
                                android:textSize="11sp"
                                android:fontFamily="@font/lexend_medium" />

                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₱"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:fontFamily="@font/lexend_bold"
                            android:background="#2C8FBD"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true" />

                    </RelativeLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- DROP-OFF payment options (Cash + GCash) -->
            <LinearLayout
                android:id="@+id/layoutPaymentDropoff"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Cash (Drop-off / Store Pick-Up claiming) -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardCash"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">

                        <RadioButton
                            android:id="@+id/rbCash"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:buttonTint="#2C8FBD" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_toEndOf="@id/rbCash"
                            android:layout_marginStart="8dp"
                            android:layout_centerVertical="true">

                            <TextView
                                android:id="@+id/tvCashLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Cash"
                                android:textColor="#1B3A5C"
                                android:textSize="14sp"
                                android:fontFamily="@font/lexend_bold" />

                            <TextView
                                android:id="@+id/tvCashSubtext"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Pay cash at the store when dropping off your laundry"
                                android:textColor="#AAAAAA"
                                android:textSize="11sp"
                                android:fontFamily="@font/lexend_medium" />

                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₱"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:fontFamily="@font/lexend_bold"
                            android:background="#2C8FBD"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true" />

                    </RelativeLayout>
                </androidx.cardview.widget.CardView>

                <!-- GCash (Drop-off) -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardGcashDropoff"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="24dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="16dp">

                            <RadioButton
                                android:id="@+id/rbGcashDropoff"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_centerVertical="true"
                                android:buttonTint="#2C8FBD" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:layout_toEndOf="@id/rbGcashDropoff"
                                android:layout_marginStart="8dp"
                                android:layout_centerVertical="true">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="GCash"
                                    android:textColor="#1B3A5C"
                                    android:textSize="14sp"
                                    android:fontFamily="@font/lexend_bold" />

                                <TextView
                                    android:id="@+id/tvGcashDropoffSubtext"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Pay via GCash now before heading to the store"
                                    android:textColor="#AAAAAA"
                                    android:textSize="11sp"
                                    android:fontFamily="@font/lexend_medium" />

                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="G"
                                android:textColor="#FFFFFF"
                                android:textSize="18sp"
                                android:fontFamily="@font/lexend_bold"
                                android:background="#007DFF"
                                android:paddingStart="10dp"
                                android:paddingEnd="10dp"
                                android:paddingTop="4dp"
                                android:paddingBottom="4dp"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true" />

                        </RelativeLayout>

                        <LinearLayout
                            android:id="@+id/layoutGcashDropoffFields"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:visibility="gone"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:paddingBottom="16dp">

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:background="#EEEEEE"
                                android:layout_marginBottom="12dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="GCash Number"
                                android:textColor="#AAAAAA"
                                android:textSize="11sp"
                                android:fontFamily="@font/lexend_medium"
                                android:layout_marginBottom="6dp" />

                            <EditText
                                android:id="@+id/etGcashDropoffNumber"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="09XX XXX XXXX"
                                android:textColor="#444444"
                                android:textColorHint="#CCCCCC"
                                android:textSize="13sp"
                                android:fontFamily="@font/lexend_medium"
                                android:background="@drawable/date_selector_bg"
                                android:padding="12dp"
                                android:inputType="phone"
                                android:maxLines="1"
                                android:layout_marginBottom="12dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Account Name"
                                android:textColor="#AAAAAA"
                                android:textSize="11sp"
                                android:fontFamily="@font/lexend_medium"
                                android:layout_marginBottom="6dp" />

                            <EditText
                                android:id="@+id/etGcashDropoffName"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Full name on GCash account"
                                android:textColor="#444444"
                                android:textColorHint="#CCCCCC"
                                android:textSize="13sp"
                                android:fontFamily="@font/lexend_medium"
                                android:background="@drawable/date_selector_bg"
                                android:padding="12dp"
                                android:inputType="textCapWords"
                                android:maxLines="1" />

                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Confirm Button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirmOrder"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Confirm Booking"
            android:textSize="15sp"
            android:textColor="#FFFFFF"
            android:fontFamily="@font/lexend_bold"
            app:backgroundTint="#1B3A5C"
            app:cornerRadius="30dp" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>