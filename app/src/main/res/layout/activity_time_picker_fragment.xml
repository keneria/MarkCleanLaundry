<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1B3A5C"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp">

        <TextView
            android:id="@+id/tvTimeHeaderLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Schedule Pickup"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:fontFamily="@font/lexend_medium" />

        <TextView
            android:id="@+id/tvSelectedTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select a time"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:fontFamily="@font/lexend_medium" />

    </LinearLayout>

    <!-- Pickers -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <NumberPicker
            android:id="@+id/pickerHour"
            android:layout_width="70dp"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=":"
            android:textSize="26sp"
            android:textColor="#1B3A5C"
            android:fontFamily="@font/lexend_bold"
            android:paddingStart="6dp"
            android:paddingEnd="6dp" />

        <NumberPicker
            android:id="@+id/pickerMinute"
            android:layout_width="70dp"
            android:layout_height="wrap_content" />

        <NumberPicker
            android:id="@+id/pickerAmPm"
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEEEEE"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp" />

    <!-- Confirm bar -->
    <LinearLayout
        android:id="@+id/btnTimeConfirm"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="#1B3A5C"
        android:layout_margin="16dp">

        <TextView
            android:id="@+id/tvTimeConfirmBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Continue"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:fontFamily="@font/lexend_bold" />

    </LinearLayout>

</LinearLayout>