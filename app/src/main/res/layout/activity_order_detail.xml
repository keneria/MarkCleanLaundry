<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#F5F5F5"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#F5F5F5"
            app:contentInsetStart="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingEnd="16dp"
                android:paddingStart="4dp">

                <ImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Back"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/back"
                    android:tint="#1B3A5C" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:fontFamily="@font/lexend_bold"
                    android:text="Order Detail"
                    android:textColor="#1B3A5C"
                    android:textSize="20sp" />

            </LinearLayout>
        </androidx.appcompat.widget.Toolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="100dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="20dp"
            android:paddingEnd="20dp"
            android:paddingStart="20dp"
            android:paddingTop="16dp">

            <!-- ===== THANK YOU HEADER ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/ivOrderIllustration"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_marginBottom="12dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/order_confirmed" />

                <TextView
                    android:id="@+id/tvHeaderTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/lexend_bold"
                    android:text="Thank you for choosing us!"
                    android:textColor="#1B3A5C"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/tvHeaderSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="@font/lexend_medium"
                    android:text="Your order has been placed"
                    android:textColor="#AAAAAA"
                    android:textSize="12sp" />

            </LinearLayout>

            <!-- ===== ORDER SUMMARY CARD ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:fontFamily="@font/lexend_bold"
                android:text="Order Summary"
                android:textColor="#1B3A5C"
                android:textSize="16sp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Order Number & Date -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:id="@+id/tvOrderNumber"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/lexend_bold"
                            android:text="Order #000"
                            android:textColor="#1B3A5C"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvBagCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="6dp"
                            android:layout_toEndOf="@id/tvOrderNumber"
                            android:fontFamily="@font/lexend_medium"
                            android:text="(0 bags)"
                            android:textColor="#AAAAAA"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tvOrderDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:fontFamily="@font/lexend_medium"
                            android:text="—"
                            android:textColor="#AAAAAA"
                            android:textSize="11sp" />

                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginBottom="14dp"
                        android:background="#EEEEEE" />

                    <!-- Service Type Row -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/lexend_medium"
                            android:text="Service Type"
                            android:textColor="#888888"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tvServiceType"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:fontFamily="@font/lexend_bold"
                            android:text="—"
                            android:textColor="#1B3A5C"
                            android:textSize="12sp" />

                    </RelativeLayout>

                    <!-- Laundry Type Row -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/lexend_medium"
                            android:text="Laundry Type"
                            android:textColor="#888888"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tvLaundryType"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:fontFamily="@font/lexend_bold"
                            android:text="—"
                            android:textColor="#1B3A5C"
                            android:textSize="12sp" />

                    </RelativeLayout>

                    <!-- Weight row -->
                    <RelativeLayout
                        android:id="@+id/layoutWeight"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/lexend_medium"
                            android:text="Weight"
                            android:textColor="#888888"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tvWeight"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:fontFamily="@font/lexend_bold"
                            android:text="—"
                            android:textColor="#1B3A5C"
                            android:textSize="12sp" />

                    </RelativeLayout>

                    <!-- Total row -->
                    <RelativeLayout
                        android:id="@+id/layoutTotal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/lexend_bold"
                            android:text="Total"
                            android:textColor="#1B3A5C"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tvTotalAmount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:fontFamily="@font/lexend_bold"
                            android:text="—"
                            android:textColor="#1B3A5C"
                            android:textSize="13sp" />

                    </RelativeLayout>

                    <!-- Delivery fee row -->
                    <RelativeLayout
                        android:id="@+id/layoutDeliveryFee"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/lexend_medium"
                            android:text="Delivery Fee"
                            android:textColor="#888888"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tvDeliveryFee"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:fontFamily="@font/lexend_bold"
                            android:text="₱50.00"
                            android:textColor="#1B3A5C"
                            android:textSize="12sp" />

                    </RelativeLayout>

                    <!-- Payment status row -->
                    <RelativeLayout
                        android:id="@+id/layoutPaymentStatus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/lexend_medium"
                            android:text="Payment Status"
                            android:textColor="#888888"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tvPaymentStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:fontFamily="@font/lexend_bold"
                            android:text="Unpaid"
                            android:textColor="#E74C3C"
                            android:textSize="12sp" />

                    </RelativeLayout>

                    <!-- Add-on items -->
                    <LinearLayout
                        android:id="@+id/llOrderItems"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        android:orientation="vertical" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginBottom="14dp"
                        android:background="#EEEEEE" />

                    <!-- Notice banner -->
                    <LinearLayout
                        android:id="@+id/layoutNotice"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="#FFF8E7"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingBottom="10dp"
                        android:paddingEnd="12dp"
                        android:paddingStart="12dp"
                        android:paddingTop="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:text="🔔"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvOrderNotice"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/lexend_medium"
                            android:lineSpacingExtra="2dp"
                            android:text=""
                            android:textColor="#B45309"
                            android:textSize="11sp" />

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ===== ORDER STATUS CARD ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:fontFamily="@font/lexend_bold"
                android:text="Order Status"
                android:textColor="#1B3A5C"
                android:textSize="16sp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <View
                                android:id="@+id/viewStatusDot"
                                android:layout_width="10dp"
                                android:layout_height="10dp"
                                android:layout_marginEnd="10dp"
                                android:background="@drawable/dot_blue" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/tvOrderStatus"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/lexend_bold"
                                    android:text="Pending"
                                    android:textColor="#F59E0B"
                                    android:textSize="14sp" />

                                <TextView
                                    android:id="@+id/tvStatusSubtext"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/lexend_medium"
                                    android:text="Waiting for admin confirmation"
                                    android:textColor="#AAAAAA"
                                    android:textSize="11sp" />

                            </LinearLayout>
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvStatusBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:fontFamily="@font/lexend_bold"
                            android:paddingBottom="4dp"
                            android:paddingEnd="10dp"
                            android:paddingStart="10dp"
                            android:paddingTop="4dp"
                            android:text="PENDING"
                            android:textColor="#F59E0B"
                            android:textSize="10sp" />

                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginBottom="12dp"
                        android:layout_marginTop="14dp"
                        android:background="#EEEEEE" />

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/lexend_medium"
                            android:text="Schedule Date"
                            android:textColor="#888888"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tvScheduleDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:fontFamily="@font/lexend_bold"
                            android:text="Not specified"
                            android:textColor="#1B3A5C"
                            android:textSize="12sp" />

                    </RelativeLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ===== ADDRESS CARD ===== -->
            <LinearLayout
                android:id="@+id/layoutAddressSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:fontFamily="@font/lexend_bold"
                    android:text="Address"
                    android:textColor="#1B3A5C"
                    android:textSize="16sp" />

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- Pickup -->
                        <LinearLayout
                            android:id="@+id/layoutPickupAddress"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <View
                                android:layout_width="10dp"
                                android:layout_height="10dp"
                                android:layout_marginEnd="12dp"
                                android:layout_marginTop="4dp"
                                android:background="@drawable/dot_blue" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/lexend_bold"
                                    android:text="Pickup Address"
                                    android:textColor="#1B3A5C"
                                    android:textSize="12sp" />

                                <TextView
                                    android:id="@+id/tvPickupAddress"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:fontFamily="@font/lexend_medium"
                                    android:text="—"
                                    android:textColor="#888888"
                                    android:textSize="12sp" />

                            </LinearLayout>
                        </LinearLayout>

                        <!-- Divider between pickup and delivery -->
                        <View
                            android:id="@+id/dividerAddress"
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginBottom="14dp"
                            android:layout_marginTop="14dp"
                            android:background="#EEEEEE"
                            android:visibility="gone" />

                        <!-- Delivery / Drop-off row -->
                        <LinearLayout
                            android:id="@+id/layoutDeliveryRow"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:visibility="gone">

                            <View
                                android:layout_width="10dp"
                                android:layout_height="10dp"
                                android:layout_marginEnd="12dp"
                                android:layout_marginTop="4dp"
                                android:background="@drawable/dot_dark" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/tvDeliveryLabel"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/lexend_bold"
                                    android:text="Drop-off at Store"
                                    android:textColor="#1B3A5C"
                                    android:textSize="12sp" />

                                <TextView
                                    android:id="@+id/tvDeliveryAddress"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:fontFamily="@font/lexend_medium"
                                    android:text="—"
                                    android:textColor="#888888"
                                    android:textSize="12sp" />

                            </LinearLayout>
                        </LinearLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- ===== PAYMENT METHOD CARD (moved below Address) ===== -->
            <LinearLayout
                android:id="@+id/layoutPaymentSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvPaymentSectionLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:fontFamily="@font/lexend_bold"
                    android:text="Payment Method"
                    android:textColor="#1B3A5C"
                    android:textSize="16sp" />

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="2dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvPaymentMethod"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/lexend_bold"
                                android:text="—"
                                android:textColor="#1B3A5C"
                                android:textSize="14sp" />

                            <TextView
                                android:id="@+id/tvPaymentSubtext"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/lexend_medium"
                                android:text="—"
                                android:textColor="#AAAAAA"
                                android:textSize="11sp" />

                            <TextView
                                android:id="@+id/tvPaymentName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/lexend_medium"
                                android:text="—"
                                android:textColor="#AAAAAA"
                                android:textSize="11sp"
                                android:visibility="gone" />

                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvPaymentIcon"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:background="#2C8FBD"
                            android:fontFamily="@font/lexend_bold"
                            android:paddingBottom="4dp"
                            android:paddingEnd="10dp"
                            android:paddingStart="10dp"
                            android:paddingTop="4dp"
                            android:text="₱"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp" />

                    </RelativeLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:orientation="vertical"
        android:paddingBottom="16dp"
        android:paddingEnd="20dp"
        android:paddingStart="20dp"
        android:paddingTop="12dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnClaimOrder"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="10dp"
            android:fontFamily="@font/lexend_bold"
            android:text="Choose Claiming Method"
            android:textSize="15sp"
            android:visibility="gone"
            app:backgroundTint="#16A085"
            app:cornerRadius="30dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnScheduleLaundry"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:fontFamily="@font/lexend_bold"
            android:text="Schedule a Laundry"
            android:textColor="#1B3A5C"
            android:textSize="15sp"
            app:backgroundTint="#FFFFFF"
            app:cornerRadius="30dp"
            app:strokeColor="#1B3A5C"
            app:strokeWidth="1.5dp" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>