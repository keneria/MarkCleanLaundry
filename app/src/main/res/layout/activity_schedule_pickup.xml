<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#F5F5F5"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#F5F5F5"
            app:contentInsetStart="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="4dp"
                android:paddingEnd="16dp">

                <ImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/back"
                    android:scaleType="fitCenter"
                    android:padding="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:tint="#1B3A5C"
                    android:contentDescription="Back" />

                <TextView
                    android:id="@+id/tvToolbarTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Schedule A Pickup"
                    android:textColor="#1B3A5C"
                    android:textSize="20sp"
                    android:fontFamily="@font/lexend_bold" />

            </LinearLayout>
        </androidx.appcompat.widget.Toolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="100dp"
        android:clipToPadding="false"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="20dp">

            <!-- ===== SERVICE TYPE ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Service Type"
                android:textColor="#1B3A5C"
                android:textSize="16sp"
                android:fontFamily="@font/lexend_bold"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvInstructionSubtext"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="We pick up from your door, or drop off your items at our store."                android:textColor="#6B7280"
                android:textSize="14sp"
                android:fontFamily="@font/lexend_medium"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp"
                android:weightSum="2">

                <LinearLayout
                    android:id="@+id/btnTogglePickup"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/toggle_active_bg"
                    android:layout_marginEnd="6dp">

                    <TextView
                        android:id="@+id/tvTogglePickup"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Home Pick Up"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:fontFamily="@font/lexend_bold" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnToggleDelivery"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/toggle_inactive_bg"
                    android:layout_marginStart="6dp">

                    <TextView
                        android:id="@+id/tvToggleDelivery"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Drop-Off"
                        android:textColor="#1B3A5C"
                        android:textSize="18sp"
                        android:fontFamily="@font/lexend_bold" />

                </LinearLayout>

            </LinearLayout>

            <!-- ===== SCHEDULE DATE ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Schedule Date"
                android:textColor="#1B3A5C"
                android:textSize="16sp"
                android:fontFamily="@font/lexend_bold"
                android:layout_marginBottom="10dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:id="@+id/sectionPickupDate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="visible">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pickup Date"
                            android:textColor="#AAAAAA"
                            android:textSize="11sp"
                            android:fontFamily="@font/lexend_medium"
                            android:layout_marginBottom="8dp" />

                        <LinearLayout
                            android:id="@+id/llPickupDate"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:background="@drawable/date_selector_bg"
                            android:padding="12dp">

                            <TextView
                                android:id="@+id/tvPickupDate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Select date"
                                android:textColor="#1B3A5C"
                                android:textSize="13sp"
                                android:fontFamily="@font/lexend_bold" />

                        </LinearLayout>

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/sectionDeliveryDate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Drop-off Date"
                            android:textColor="#AAAAAA"
                            android:textSize="11sp"
                            android:fontFamily="@font/lexend_medium"
                            android:layout_marginBottom="8dp" />

                        <LinearLayout
                            android:id="@+id/llDeliveryDate"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:background="@drawable/date_selector_bg"
                            android:padding="12dp">

                            <TextView
                                android:id="@+id/tvDeliveryDate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Select date"
                                android:textColor="#1B3A5C"
                                android:textSize="13sp"
                                android:fontFamily="@font/lexend_bold" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ===== SCHEDULE TIME ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Schedule Time"
                android:textSize="16sp"
                android:textColor="#1B3A5C"
                android:fontFamily="@font/lexend_bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Time slots are available from 8:00 AM to 6:00 PM only."
                android:textSize="12sp"
                android:textColor="#888888"
                android:fontFamily="@font/lexend_medium"
                android:layout_marginBottom="8dp" />


            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:id="@+id/sectionPickupTime"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="visible">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pickup Time"
                            android:textColor="#AAAAAA"
                            android:textSize="11sp"
                            android:fontFamily="@font/lexend_medium"
                            android:layout_marginBottom="8dp" />

                        <LinearLayout
                            android:id="@+id/llPickupTime"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:background="@drawable/date_selector_bg"
                            android:padding="12dp">

                            <TextView
                                android:id="@+id/tvPickupTime"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Select time"
                                android:textColor="#1B3A5C"
                                android:textSize="13sp"
                                android:fontFamily="@font/lexend_bold" />

                        </LinearLayout>

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/sectionDeliveryTime"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Drop-off Time"
                            android:textColor="#AAAAAA"
                            android:textSize="11sp"
                            android:fontFamily="@font/lexend_medium"
                            android:layout_marginBottom="8dp" />

                        <LinearLayout
                            android:id="@+id/llDeliveryTime"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:background="@drawable/date_selector_bg"
                            android:padding="12dp">

                            <TextView
                                android:id="@+id/tvDeliveryTime"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Select time"
                                android:textColor="#1B3A5C"
                                android:textSize="13sp"
                                android:fontFamily="@font/lexend_bold" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Continue Button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirmOrder"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Continue"
            android:textSize="15sp"
            android:textColor="#FFFFFF"
            android:fontFamily="@font/lexend_bold"
            app:backgroundTint="#1B3A5C"
            app:cornerRadius="30dp" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>