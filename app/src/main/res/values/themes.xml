<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.MarkCleanLaundry" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
    </style>

    <style name="Theme.MarkCleanLaundry" parent="Base.Theme.MarkCleanLaundry" />

    <style name="DatePickerTheme" parent="Theme.MaterialComponents.Light.Dialog">
        <item name="android:datePickerStyle">@style/DatePickerStyle</item>
        <item name="buttonBarPositiveButtonStyle">@style/DialogPositiveButton</item>
        <item name="buttonBarNegativeButtonStyle">@style/DialogNegativeButton</item>
    </style>

    <style name="DatePickerStyle" parent="android:Widget.Material.DatePicker">
        <item name="android:headerBackground">#1B3A5C</item>
    </style>

    <style name="DialogPositiveButton" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:text">Done</item>
        <item name="android:textColor">#1B3A5C</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="DialogNegativeButton" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="DatePickerButton" parent="Widget.AppCompat.Button.ButtonBar.AlertDialog">
        <item name="android:textColor">#2C8FBD</item>
        <item name="android:textSize">14sp</item>
    </style>
    <style name="CalendarDateText">
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">#1B3A5C</item>
    </style>

    <style name="CalendarWeekDay">
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">#AAAAAA</item>
    </style>
</resources>